---
// src/components/MomentsScript.astro
---

<!-- 載入 EXIF 與 GSAP 庫 -->
<script src="https://cdn.jsdelivr.net/npm/exifreader@4.21.0/dist/exif-reader.js" is:inline></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>

<script is:inline>
  let momentsData = [];
  try {
    const jsonEl = document.getElementById('moments-json');
    if (jsonEl) {
      momentsData = JSON.parse(jsonEl.textContent);
    }
  } catch (e) {
    console.error("Failed to parse moments data:", e);
  }

  let currentActiveMomentId = momentsData[0]?.id || null;
  let activeImageIndex = 0;

  // 檢測效能降級狀態
  const isDegradedMode = () => document.documentElement.classList.contains('perf-degraded');

  document.addEventListener('astro:page-load', () => {
    const timelineItems = document.querySelectorAll('.timeline-item');
    const detailCards = document.querySelectorAll('.detail-card');
    const yearSelect = document.getElementById('year-select');
    const monthSelect = document.getElementById('month-select');

    const initialActiveCard = document.querySelector('.detail-card.active');
    if (initialActiveCard) {
      const elements = initialActiveCard.querySelectorAll('.animate-el');
      const mediaBoxes = initialActiveCard.querySelectorAll('.media-box');
      const isDegraded = isDegradedMode();
      
      gsap.fromTo(elements, 
        { opacity: 0, y: isDegraded ? 0 : 25, scale: isDegraded ? 1 : 0.98 }, 
        { opacity: 1, y: 0, scale: 1, duration: isDegraded ? 0.05 : 0.5, stagger: isDegraded ? 0 : 0.06, ease: "power3.out" }
      );
      if (mediaBoxes.length > 0) {
        gsap.fromTo(mediaBoxes,
          { opacity: 0, scale: isDegraded ? 1 : 0.85 },
          { opacity: 1, scale: 1, duration: isDegraded ? 0.05 : 0.45, stagger: isDegraded ? 0 : 0.05, ease: "back.out(1.5)", delay: isDegraded ? 0 : 0.2 }
        );
      }
    }

    function switchDetail(id) {
      currentActiveMomentId = id;
      const isDegraded = isDegradedMode();

      detailCards.forEach(card => {
        const isTarget = card.getAttribute('data-detail-id') === id;
        if (isTarget) {
          card.classList.add('active');
          
          const elements = card.querySelectorAll('.animate-el');
          const mediaBoxes = card.querySelectorAll('.media-box');

          gsap.fromTo(elements, 
            { opacity: 0, y: isDegraded ? 0 : 25, scale: isDegraded ? 1 : 0.98 }, 
            { opacity: 1, y: 0, scale: 1, duration: isDegraded ? 0.05 : 0.5, stagger: isDegraded ? 0 : 0.06, ease: "power3.out", overwrite: "auto" }
          );

          if (mediaBoxes.length > 0) {
            gsap.fromTo(mediaBoxes,
              { opacity: 0, scale: isDegraded ? 1 : 0.8 },
              { opacity: 1, scale: 1, duration: isDegraded ? 0.05 : 0.4, stagger: isDegraded ? 0 : 0.04, ease: "back.out(1.4)", delay: isDegraded ? 0 : 0.12, overwrite: "auto" }
            );
          }
        } else {
          card.classList.remove('active');
        }
      });
    }

    function filterTimeline() {
      const selectedYear = yearSelect.value;
      const selectedMonth = monthSelect.value;

      let firstVisibleId = null;

      timelineItems.forEach(item => {
        const itemYear = item.getAttribute('data-year');
        const itemMonth = item.getAttribute('data-month');

        const matchYear = (selectedYear === 'all' || itemYear === selectedYear);
        const matchMonth = (selectedMonth === 'all' || itemMonth === selectedMonth);

        if (matchYear && matchMonth) {
          item.style.display = 'flex';
          if (!firstVisibleId) {
            firstVisibleId = item.getAttribute('data-id');
          }
        } else {
          item.style.display = 'none';
        }
      });

      if (firstVisibleId) {
        const activeTimeline = document.querySelector('.timeline-item.active');
        if (!activeTimeline || activeTimeline.style.display === 'none') {
          timelineItems.forEach(i => i.classList.remove('active'));
          const targetEl = document.querySelector(`.timeline-item[data-id="${firstVisibleId}"]`);
          if (targetEl) {
            targetEl.classList.add('active');
            switchDetail(firstVisibleId);
            if (!isDegradedMode()) {
              gsap.fromTo(targetEl, { scale: 0.95 }, { scale: 1, duration: 0.3, ease: "back.out(1.2)" });
            }
          }
        }
      }
    }

    if (yearSelect) yearSelect.addEventListener('change', filterTimeline);
    if (monthSelect) monthSelect.addEventListener('change', filterTimeline);

    timelineItems.forEach(item => {
      item.addEventListener('click', () => {
        if (item.style.display === 'none') return;
        timelineItems.forEach(i => i.classList.remove('active'));
        item.classList.add('active');

        if (!isDegradedMode()) {
          gsap.fromTo(item, { scale: 0.97 }, { scale: 1, duration: 0.3, ease: "back.out(1.5)" });
        }

        const id = item.getAttribute('data-id');
        switchDetail(id);
      });
    });

    document.addEventListener('click', (e) => {
      const box = e.target.closest('.media-box');
      if (!box) return;
      const momentId = box.getAttribute('data-moment-id');
      const index = parseInt(box.getAttribute('data-index'), 10);
      
      const moment = momentsData.find(m => m.id === momentId);
      if (moment && !isNaN(index)) {
        currentActiveMomentId = momentId;
        openLightbox(index);
      }
    });

    // 動態點讚
    document.addEventListener('click', (e) => {
      const btn = e.target.closest('.post-like-btn');
      if (!btn) return;

      const card = btn.closest('.detail-card');
      const avatarsContainer = card.querySelector('.likes-avatars');
      const isLiked = btn.classList.contains('liked');

      if (isLiked) {
        btn.classList.remove('liked');
        const myTag = avatarsContainer.querySelector('.avatar-tag.my-like');
        if (myTag) myTag.remove();
      } else {
        btn.classList.add('liked');
        const newTag = document.createElement('span');
        newTag.className = 'avatar-tag my-like';
        newTag.textContent = '我';
        avatarsContainer.prepend(newTag);
        if (!isDegradedMode()) {
          gsap.fromTo(btn, { scale: 0.8 }, { scale: 1, duration: 0.3, ease: "back.out(2)" });
        }
      }
    });

    // 評論點讚
    document.addEventListener('click', (e) => {
      const btn = e.target.closest('.comment-like-btn');
      if (!btn) return;
      
      const heart = btn.querySelector('.like-heart');
      const numSpan = btn.querySelector('.like-num');
      let count = parseInt(numSpan.textContent, 10) || 0;
      
      const isLiked = btn.classList.contains('liked');
      
      if (isLiked) {
        btn.classList.remove('liked');
        heart.textContent = '♡';
        count = Math.max(0, count - 1);
      } else {
        btn.classList.add('liked');
        heart.textContent = '♥';
        count += 1;
        if (!isDegradedMode()) {
          gsap.fromTo(btn, { scale: 0.85 }, { scale: 1, duration: 0.3, ease: "back.out(2)" });
        }
      }
      numSpan.textContent = count;
    });
  });

  const lightbox = document.getElementById('lightbox');
  const lbBaseImg = document.getElementById('lb-base-img');
  const lbLoader = document.getElementById('lb-loader');
  
  const lbIndex = document.getElementById('lightbox-index');
  const lbDate = document.getElementById('lightbox-date');
  const lbLocation = document.getElementById('lightbox-location');
  const footerLink = document.getElementById('footer-link');

  const exifContainer = document.getElementById('lightbox-exif');
  const exifCamera = document.getElementById('exif-camera');
  const exifParam = document.getElementById('exif-param');

  // 解析並顯示 EXIF 資訊
  async function parseAndShowExif(imgUrl) {
    exifContainer.style.display = 'none';
    exifCamera.textContent = '';
    exifParam.textContent = '';

    if (typeof ExifReader === 'undefined' || imgUrl.startsWith('data:')) return;

    try {
      const tags = await ExifReader.load(imgUrl, { async: true });
      
      const make = tags.Make ? tags.Make.description : '';
      const model = tags.Model ? tags.Model.description : '';
      let camera = model;
      if (make && model && !model.toLowerCase().includes(make.toLowerCase())) {
        camera = `${make} ${model}`;
      }

      const focalLength = tags.FocalLength ? `${tags.FocalLength.description}mm` : '';
      const fNumber = tags.FNumber ? `f/${tags.FNumber.description}` : '';
      const exposureTime = tags.ExposureTime ? `${tags.ExposureTime.description}s` : '';
      const iso = tags.ISOSpeedRatings || tags.ISO ? `ISO ${tags.ISOSpeedRatings?.description || tags.ISO?.description}` : '';

      const params = [focalLength, fNumber, exposureTime, iso].filter(Boolean).join('  ');

      if (camera || params) {
        if (camera) exifCamera.textContent = `📷 ${camera}`;
        if (params) exifParam.textContent = `⚙️ ${params}`;
        exifContainer.style.display = 'flex';
      }
    } catch (e) {
    }
  }

  window.openLightbox = (index) => {
    const moment = momentsData.find(m => m.id === currentActiveMomentId);
    if (!moment || !moment.images) return;
    activeImageIndex = index;
    const imgUrl = moment.images[index];
    if (!imgUrl) return;

    lightbox.classList.add('active');
    const isDegraded = isDegradedMode();
    
    gsap.fromTo('.lightbox-content', 
      { scale: isDegraded ? 1 : 0.9, y: isDegraded ? 0 : 25, opacity: 0 }, 
      { scale: 1, y: 0, opacity: 1, duration: isDegraded ? 0.05 : 0.5, ease: "expo.out" }
    );

    lbIndex.innerText = `#${index + 1} / ${moment.images.length}`;
    lbDate.innerText = moment.time;
    
    if (moment.location) {
      lbLocation.innerText = `📍 ${moment.location}`;
      lbLocation.style.display = 'inline-block';
    } else {
      lbLocation.style.display = 'none';
    }

    footerLink.href = imgUrl;

    lbBaseImg.className = 'lightbox-layer opacity-hidden';
    lbLoader.style.display = 'block';

    lbBaseImg.onload = () => {
      lbLoader.style.display = 'none';
      lbBaseImg.classList.remove('opacity-hidden');
    };

    lbBaseImg.onerror = () => {
      lbLoader.style.display = 'none';
      lbBaseImg.classList.remove('opacity-hidden');
    };

    lbBaseImg.src = imgUrl;

    if (lbBaseImg.complete) {
      lbLoader.style.display = 'none';
      lbBaseImg.classList.remove('opacity-hidden');
    }

    parseAndShowExif(imgUrl);
  };

  const closeLightbox = () => {
    const isDegraded = isDegradedMode();
    gsap.to('.lightbox-content', {
      scale: isDegraded ? 1 : 0.95, y: isDegraded ? 0 : 15, opacity: 0, duration: isDegraded ? 0.05 : 0.3, ease: "power2.in", onComplete: () => {
        lightbox.classList.remove('active');
        lbBaseImg.src = ''; 
        lbLoader.style.display = 'none';
        exifContainer.style.display = 'none';
      }
    });
  };

  document.getElementById('lightbox-close-btn').addEventListener('click', closeLightbox);
  document.getElementById('lightbox-close-area').addEventListener('click', closeLightbox);
  
  document.getElementById('prev-btn').addEventListener('click', () => { 
    const moment = momentsData.find(m => m.id === currentActiveMomentId);
    if (moment && activeImageIndex > 0) openLightbox(activeImageIndex - 1); 
  });
  
  document.getElementById('next-btn').addEventListener('click', () => { 
    const moment = momentsData.find(m => m.id === currentActiveMomentId);
    if (moment && activeImageIndex < moment.images.length - 1) openLightbox(activeImageIndex + 1); 
  });

  document.addEventListener('keydown', (e) => {
    if (!lightbox || !lightbox.classList.contains('active')) return;
    const moment = momentsData.find(m => m.id === currentActiveMomentId);
    if (!moment) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft' && activeImageIndex > 0) openLightbox(activeImageIndex - 1);
    if (e.key === 'ArrowRight' && activeImageIndex < moment.images.length - 1) openLightbox(activeImageIndex + 1);
  });
</script>