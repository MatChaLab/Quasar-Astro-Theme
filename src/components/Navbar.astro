---
// src/components/Navbar.astro
import { SITE_CONFIG, NAVBAR_CONFIG } from '../config';
import PerformanceGuard from './PerformanceGuard.astro';
---

<header 
  class="quasar-navbar" 
  id="quasar-navbar-element" 
  define:vars={{ themeColor: SITE_CONFIG.themeColor }}
  data-restored={NAVBAR_CONFIG.perfRestored}
  data-manual-degraded={NAVBAR_CONFIG.perfManualDegraded}
  data-light={NAVBAR_CONFIG.themeLight}
  data-dark={NAVBAR_CONFIG.themeDark}
>
 <div id="search-data-store" data-json={JSON.stringify(NAVBAR_CONFIG.searchData)} style="display: none;"></div>
 <div class="liquid-glass-bg"></div>

 <div class="nav-container">
   <!-- 左側區塊 -->
   <div class="nav-left">
     <a href="/" class="brand-link" id="nav-logo" title={SITE_CONFIG.title}>
       <Fragment set:html={SITE_CONFIG.logoIconPath} />
       <span class="brand-text">{SITE_CONFIG.title}</span>
     </a>
     <div class="loading-spinner" id="nav-spinner">
       <svg viewBox="0 0 50 50" class="spinner-svg">
         <circle cx="25" cy="25" r="20" fill="none" stroke-width="5" class="spinner-path"></circle>
       </svg>
     </div>
     <div class="album-cache-status" id="album-cache-status">
       <span class="status-divider">|</span>
       <span class="status-text" id="status-text-display"></span>
     </div>
   </div>

   <!-- 中間內容包裝層 -->
   <div class="nav-content-wrapper">
     <!-- 標籤頁導航 -->
     <nav class="nav-center" id="nav-center">
       {NAVBAR_CONFIG.navItems.map((item) => (
         <a href={item.url} class="nav-link">
           <span class="link-text">{item.label}</span>
         </a>
       ))}
     </nav>

     <!-- 動態提示語面板（內嵌倒計時圓圈） -->
     <div class="perf-warning-notice" id="nav-perf-alert">
       <div class="countdown-circle-wrapper">
         <svg class="countdown-svg" viewBox="0 0 20 20">
           <circle class="countdown-bg" cx="10" cy="10" r="8"></circle>
           <circle class="countdown-bar" id="countdown-circle-bar" cx="10" cy="10" r="8"></circle>
         </svg>
       </div>
       <span id="perf-alert-text"></span>
     </div>

     <!-- 搜尋框 -->
     <div class="search-box-wrapper" id="search-box-wrapper">
       <input type="text" class="search-input" id="search-input" placeholder={NAVBAR_CONFIG.searchBox} autocomplete="off" />
       <div class="search-results-panel" id="search-results-panel"></div>
     </div>
   </div>

   <!-- 右側區塊（按鈕排序：搜尋 -> 主題 -> 性能） -->
   <div class="nav-right">
     <!-- 1. 搜尋按鈕 -->
     <button class="icon-btn search-trigger" id="search-trigger-btn" aria-label="Toggle Search">
       <svg viewBox="0 0 24 24" fill="none" class="action-icon" xmlns="http://www.w3.org/2000/svg">
         <path d="M21 21L15 15M17 10C17 13.866 13.866 17 10 17C6.13401 17 3 13.866 3 10C3 6.13401 6.13401 3 10 3C13.866 3 17 6.13401 17 10Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
       </svg>
     </button>

     <!-- 2. 日夜模式按鈕 -->
     <button class="icon-btn theme-toggle" id="theme-toggle-btn" aria-label="Toggle Theme">
       <svg viewBox="0 0 24 24" fill="none" class="action-icon icon-sun" xmlns="http://www.w3.org/2000/svg">
         <circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="2,35"/>
         <path d="M12 2V4M12 20V22M4 12H2M22 12H20M19.0711 19.0711L17.6569 17.6569M6.34315 6.34315L4.92893 4.92893M19.0711 4.92893L17.6569 6.34315M6.34315 17.6569L4.92893 19.0711" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
       </svg>
       <svg viewBox="0 0 24 24" fill="none" class="action-icon icon-moon" xmlns="http://www.w3.org/2000/svg">
         <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
       </svg>
     </button>

     <!-- 3. 性能切換按鈕 -->
     <button class="icon-btn perf-status-toggle" id="perf-toggle-btn" aria-label="Toggle Animation Quality">
       <!-- 正常打勾圓圈 -->
       <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="action-icon icon-perf-check" stroke-linecap="round" stroke-linejoin="round">
         <circle cx="12" cy="12" r="10"/><path d="M22 4L12 14.01l-3-3"/>
       </svg>
       <!-- 降級三角形警告 -->
       <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="action-icon icon-perf-warn" stroke-linecap="round" stroke-linejoin="round">
         <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
       </svg>
     </button>
   </div>
 </div>

 <div class="nav-progress-bar" id="nav-progress"></div>
 
 <PerformanceGuard />
</header>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const searchTrigger = document.getElementById('search-trigger-btn');
    const searchWrapper = document.getElementById('search-box-wrapper');
    const searchInput = document.getElementById('search-input');
    const navCenter = document.getElementById('nav-center');
    const themeBtn = document.getElementById('theme-toggle-btn');
    
    const navbarMain = document.getElementById('quasar-navbar-element');
    const perfBtn = document.getElementById('perf-toggle-btn');
    const perfAlert = document.getElementById('nav-perf-alert');
    const perfAlertText = document.getElementById('perf-alert-text');
    const countdownBar = document.getElementById('countdown-circle-bar');
    
    let isSearchOpen = false;
    let alertTimer = null;

    function triggerNavbarNotice(msg, duration = 4000, isRedAlert = false) {
      if (perfAlertText) perfAlertText.innerText = msg;
      clearTimeout(alertTimer);

      if (isRedAlert) {
        perfAlert.classList.add('is-red-warning');
      } else {
        perfAlert.classList.remove('is-red-warning');
      }

      if (countdownBar) {
        gsap.killTweensOf(countdownBar);
        gsap.set(countdownBar, { strokeDashoffset: 0 });
        gsap.to(countdownBar, {
          strokeDashoffset: 50.26,
          duration: duration / 1000,
          ease: "none"
        });
      }

      gsap.to(navCenter, { opacity: 0, scale: 0.98, pointerEvents: 'none', duration: 0.35, ease: "power2.out" });
      gsap.to(perfAlert, { opacity: 1, scale: 1, pointerEvents: 'auto', duration: 0.35, ease: "power2.out" });

      alertTimer = setTimeout(() => {
        gsap.to(perfAlert, { opacity: 0, scale: 0.98, pointerEvents: 'none', duration: 0.35, ease: "power2.in" });
        gsap.to(navCenter, { opacity: 1, scale: 1, pointerEvents: 'auto', duration: 0.35, ease: "power2.out" });
      }, duration);
    }

    if (searchTrigger) {
      searchTrigger.addEventListener('mouseenter', () => {
        if (!isSearchOpen) {
          isSearchOpen = true;
          gsap.to(searchWrapper, { width: 360, opacity: 1, duration: 0.75, ease: "expo.out" });
          gsap.to(navCenter, { opacity: 0.15, scale: 0.95, duration: 0.4, ease: "power2.out" });
          setTimeout(() => searchInput.focus(), 50); 
        }
      });
    }

    document.addEventListener('click', (e) => {
      if (isSearchOpen && !searchWrapper.contains(e.target) && !searchTrigger.contains(e.target)) {
        isSearchOpen = false;
        gsap.to(searchWrapper, { width: 0, opacity: 0, duration: 0.4, ease: "expo.in" });
        gsap.to(navCenter, { opacity: 1, scale: 1, duration: 0.4, ease: "power2.out" });
        searchInput.value = ''; 
      }
    });

    window.addEventListener('quasar-perf-status', (e) => {
      const { status, text } = e.detail;
      sessionStorage.setItem('quasar-perf', status);
      
      if (status === 'degraded') {
        if (navbarMain) navbarMain.classList.add('perf-degraded');
        document.documentElement.classList.add('perf-degraded');
        window.dispatchEvent(new CustomEvent('earth-quality-engine', { detail: { mode: 'low' } }));
        if (text) triggerNavbarNotice(text, 7000, true);
      } else if (status === 'high') {
        if (navbarMain) navbarMain.classList.remove('perf-degraded');
        document.documentElement.classList.remove('perf-degraded');
        window.dispatchEvent(new CustomEvent('earth-quality-engine', { detail: { mode: 'high' } }));
        if (navbarMain) triggerNavbarNotice(navbarMain.dataset.restored, 4000, false);
      }
    });

    if (perfBtn) {
      perfBtn.addEventListener('click', () => {
        const isCurrentlyDegraded = document.documentElement.classList.contains('perf-degraded');
        if (isCurrentlyDegraded) {
          window.dispatchEvent(new CustomEvent('quasar-perf-force'));
        } else {
          window.dispatchEvent(new CustomEvent('quasar-perf-status', {
            detail: { status: 'degraded', text: navbarMain ? navbarMain.dataset.manualDegraded : '' }
          }));
        }
        gsap.fromTo(perfBtn, { scale: 0.8 }, { scale: 1, duration: 0.4, ease: "back.out(2)" });
      });
    }

    if (themeBtn) {
      themeBtn.addEventListener('click', () => {
        document.documentElement.classList.toggle('light-mode');
        const isLight = document.documentElement.classList.contains('light-mode');
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
        gsap.fromTo(themeBtn, { scale: 0.8 }, { scale: 1, duration: 0.3, ease: "elastic.out(1.5, 0.5)" });
        
        const noticeMsg = isLight ? (navbarMain ? navbarMain.dataset.light : '') : (navbarMain ? navbarMain.dataset.dark : '');
        triggerNavbarNotice(noticeMsg, 3500, false);
      });
    }
  });
</script>

<style>
 .quasar-navbar { position: fixed; top: 0; left: 0; width: 100vw; height: 72px; z-index: 100; font-family: 'Noto Sans SC', sans-serif; }
 .liquid-glass-bg { position: absolute; inset: 0; background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(32px) saturate(210%); border-bottom: 1px solid rgba(255, 255, 255, 0.06); pointer-events: none; z-index: 1; mix-blend-mode: color-dodge; transition: background 0.4s ease, mix-blend-mode 0.4s ease; }
 .nav-container { position: relative; z-index: 2; max-width: 90%; margin: 0 auto; height: 100%; display: flex; justify-content: space-between; align-items: center; padding: 0 40px; }
 
 .nav-left { display: flex; align-items: center; gap: 12px; flex-shrink: 0; }
 .brand-link { display: flex; align-items: center; gap: 10px; text-decoration: none; color: #ffffff; transition: opacity 0.2s ease; flex-shrink: 0; }
 .brand-link svg, :global(.brand-link svg) { width: 22px; height: 22px; flex-shrink: 0; display: block; }
 .brand-text { font-weight: 900; font-size: 1.15rem; letter-spacing: 0.02em; white-space: nowrap; flex-shrink: 0; }
 
 .loading-spinner { width: 16px; height: 16px; opacity: 0; transform: scale(0.5); transition: all 0.3s ease; }
 .album-cache-status { display: flex; align-items: center; gap: 12px; opacity: 0; transform: translateX(-10px); }
 .status-divider { color: rgba(255, 255, 255, 0.15); font-weight: 300; }
 .status-text { font-family: 'Plus Jakarta Sans', monospace; font-size: 0.65rem; font-weight: 700; color: var(--themeColor); }
 
 .nav-content-wrapper { display: flex; align-items: center; justify-content: center; position: relative; flex: 1; height: 100%; }
 .nav-center { display: flex; align-items: center; gap: 32px; transition: all 0.35s ease; will-change: transform, opacity; }
 
 .perf-warning-notice { position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%) scale(0.98); width: max-content; pointer-events: none; opacity: 0; font-size: 0.85rem; font-weight: 500; color: #ffffff; letter-spacing: 0.02em; text-shadow: 0 0 12px rgba(255, 255, 255, 0.1); will-change: transform, opacity; display: flex; align-items: center; gap: 8px; }
 .perf-warning-notice.is-red-warning { color: #ff3e18 !important; text-shadow: 0 0 12px rgba(255, 62, 24, 0.2) !important; }

 .countdown-circle-wrapper { display: inline-flex; align-items: center; justify-content: center; width: 16px; height: 16px; position: relative; }
 .countdown-svg { width: 16px; height: 16px; transform: rotate(-90deg); }
 .countdown-bg { fill: none; stroke: rgba(255, 255, 255, 0.15); stroke-width: 2.5; }
 :global(.light-mode) .countdown-bg { stroke: rgba(0, 0, 0, 0.08); }
 .countdown-bar { fill: none; stroke: currentColor; stroke-width: 2.5; stroke-linecap: round; stroke-dasharray: 50.26; stroke-dashoffset: 0; }

 .nav-link { position: relative; text-decoration: none; color: #999999; font-size: 0.85rem; font-weight: 500; padding: 8px 0; transition: color 0.3s ease; }
 .nav-link:hover { color: #ffffff; }
 .nav-link::after { content: ''; position: absolute; bottom: 2px; left: 0; width: 100%; height: 1.5px; background-color: #ffffff; transform: scaleX(0); transform-origin: left; transition: transform 0.4s ease; }
 .nav-link:hover::after { transform: scaleX(1); }
 .search-box-wrapper { position: absolute; right: 0; top: 50%; transform: translateY(-50%); width: 0; height: 36px; opacity: 0; z-index: 10; display: flex; align-items: center; pointer-events: none; }
 .search-box-wrapper[style*="width: 360px"] { pointer-events: auto; }
 .search-input { width: 100%; height: 100%; background: rgba(255, 255, 255, 0.08); border: none; border-radius: 18px; padding: 0 16px; color: #ffffff; font-size: 0.85rem; outline: none; border: 1px solid rgba(255, 255, 255, 0.06); }
 .search-results-panel { position: absolute; top: calc(100% + 10px); left: 0; width: 100%; max-height: 0; background: rgba(20, 20, 20, 0.95); backdrop-filter: blur(16px); border-radius: 12px; opacity: 0; transition: all 0.4s ease; }
 
 .nav-right { display: flex; align-items: center; gap: 16px; position: relative; z-index: 5; }
 .icon-btn { background: transparent; border: none; color: #cccccc; cursor: pointer; width: 36px; height: 36px; border-radius: 50%; display: flex; justify-content: center; align-items: center; transition: all 0.2s ease; position: relative; }
 .icon-btn:hover { color: #ffffff; background: rgba(255, 255, 255, 0.1); }
 .action-icon { width: 18px; height: 18px; }
 
 .perf-status-toggle .icon-perf-check { display: block; color: var(--themeColor); }
 .perf-status-toggle .icon-perf-warn { display: none; color: #ff3e18; }
 :global(.perf-degraded) .quasar-navbar .perf-status-toggle .icon-perf-check,
 .quasar-navbar.perf-degraded .perf-status-toggle .icon-perf-check { display: none; }
 :global(.perf-degraded) .quasar-navbar .perf-status-toggle .icon-perf-warn,
 .quasar-navbar.perf-degraded .perf-status-toggle .icon-perf-warn { display: block; }

 .theme-toggle .icon-sun, .theme-toggle .icon-moon { position: absolute; }
 .theme-toggle .icon-sun { opacity: 0; transform: rotate(90deg) scale(0.5); }
 .nav-progress-bar { position: absolute; bottom: -1px; left: 0; height: 2px; width: 0%; background: var(--themeColor); opacity: 0; }

 /* ── 明亮模式優化區塊 ── */
 :global(.light-mode) body { background-color: #f5f5f7 !important; color: #1d1d1f !important; }
 :global(.light-mode) .liquid-glass-bg { background: rgba(255, 255, 255, 0.75); border-bottom: 1px solid rgba(0, 0, 0, 0.08); mix-blend-mode: normal; backdrop-filter: blur(32px) saturate(210%); }
 :global(.light-mode) .brand-link { color: #1d1d1f; }
 :global(.light-mode) .nav-link { color: #555555; }
 :global(.light-mode) .nav-link:hover { color: #000000; }
 :global(.light-mode) .nav-link::after { background-color: #000000; }
 
 :global(.light-mode) .perf-warning-notice { color: #1d1d1f; text-shadow: none; }
 
 :global(.light-mode) .icon-btn { color: #1d1d1f !important; opacity: 1 !important; }
 :global(.light-mode) .icon-btn:hover { background: rgba(0, 0, 0, 0.06); color: #000000 !important; }
 :global(.light-mode) .action-icon { color: #1d1d1f !important; opacity: 1 !important; }
 
 :global(.light-mode) .theme-toggle .icon-moon { opacity: 0; transform: rotate(-90deg) scale(0.5); }
 :global(.light-mode) .theme-toggle .icon-sun { opacity: 1; transform: rotate(0deg) scale(1); }
 :global(.light-mode) .status-divider { color: rgba(0, 0, 0, 0.1); }
</style>