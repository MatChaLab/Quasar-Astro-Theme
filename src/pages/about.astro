---
// src/pages/about.astro
import { SITE_CONFIG, ABOUT_CONFIG } from '../config';
import { ClientRouter } from 'astro:transitions'; 
import Navbar from '../components/Navbar.astro';
import Earth from '../components/Earth.astro';

// 自動解析中英文 retirement 標籤
const [yearEn, yearZh] = ABOUT_CONFIG.retirement.labels.year.split(' / ');
const [monthEn, monthZh] = ABOUT_CONFIG.retirement.labels.month.split(' / ');
const [dayEn, dayZh] = ABOUT_CONFIG.retirement.labels.day.split(' / ');

// 動態拆分左側 Bento 標題的中英文
const [leftTitleEn, leftTitleZh] = ABOUT_CONFIG.retirement.leftTitle.split(' / ');
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>About | {SITE_CONFIG.title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
  
  <ClientRouter />

  <style is:inline set:html={`
    :root {
      --page-theme-color: ${SITE_CONFIG.themeColor};
    }
  `} />
</head>
<body>

  <Navbar />
  
  <div class="earth-horizon-layer">
    <Earth transition:persist="earth-canvas" />
  </div>

  <main class="about-cinematic-viewport opacity-0">
    
    <!-- 階段 1：核心能力卡 -->
    <section class="story-stage active" id="stage-capabilities">
      <div class="stage-inner flex-center">
        <div class="avatar-wrapper anim-s1-avatar">
          <img src={ABOUT_CONFIG.avatar.src} alt={ABOUT_CONFIG.avatar.alt} class="about-avatar-img" />
        </div>
        
        <h1 class="stage-title-large anim-s1-title">About Me.</h1>
        
        <div class="skills-grid-wrapper">
          {ABOUT_CONFIG.skills.map((skill) => (
            <div class="unified-glass-card anim-s1-card">
              <div class="card-inner-brand">{skill.title}</div>
              <div class="card-inner-sub">{skill.sub}</div>
            </div>
          ))}
        </div>

        <p class="manifesto-claim anim-s1-claim">{ABOUT_CONFIG.manifesto}</p>
      </div>
    </section>

    <!-- 階段 2：項目矩陣圖塊雲 -->
    <section class="story-stage" id="stage-mosaic">
      <div class="stage-inner flex-center">
        <div class="mosaic-content-holder">
          <h2 class="mosaic-main-header">{ABOUT_CONFIG.mosaicHeader.title}</h2>
          <p class="mosaic-main-sub">{ABOUT_CONFIG.mosaicHeader.subtitle}</p>
        </div>

        <div class="mosaic-cloud-flexbox">
          {ABOUT_CONFIG.mosaicMatrix.map((item) => (
            <div class="mosaic-drag-card" data-rot={item.rotate.replace('deg', '')}>
              <div class="card-tag">{item.tag}</div>
              <h4 class="card-title">{item.title}</h4>
              <div class="card-glare"></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 階段 3：深度看板樣式 -->
    <section class="story-stage" id="stage-deepdive">
      <div class="stage-inner flex-center">
        <div class="spotlight-container">
          <div class="spotlight" id="spotlight-1"></div>
          <div class="spotlight" id="spotlight-2"></div>
          <div class="spotlight" id="spotlight-3"></div>
        </div>

        <div class="deepdive-content-holder">
          <h2 class="deepdive-main-header">{ABOUT_CONFIG.deepDives.sectionHeader}</h2>
          <p class="deepdive-main-sub">{ABOUT_CONFIG.deepDives.sectionSub}</p>
          
          <div class="deepdive-pillars-matrix">
            {ABOUT_CONFIG.deepDives.pillars.map((pillar) => (
              <div class="pillar-glass-block">
                <div class="pillar-inner-glow"></div>
                <h3 class="pillar-title">{pillar.title}</h3>
                <p class="pillar-desc">{pillar.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- 階段 4：Bento 模組化退休倒計時 -->
    <section 
      class="story-stage" 
      id="stage-retirement" 
      data-start-date={ABOUT_CONFIG.retirement.startDate}
      data-target-date={ABOUT_CONFIG.retirement.targetDate}
    >
      <div class="stage-inner flex-center">
        
        <div class="retirement-content-holder anim-s4-title-fade">
          <h2 class="retirement-main-header">{ABOUT_CONFIG.retirement.title}</h2>
          <p class="retirement-main-sub">{ABOUT_CONFIG.retirement.subtitle}</p>
        </div>

        <div class="bento-container">
          
          <!-- 左側 -->
          <div class="bento-card bento-left anim-s4-card-unit">
            <div class="bento-left-brand">
              <span class="brand-en">{leftTitleEn}</span>
              {leftTitleZh && <span class="brand-zh">{leftTitleZh}</span>}
            </div>
            <p class="bento-left-desc">{ABOUT_CONFIG.retirement.description}</p>
          </div>

          <!-- 中間 -->
          <div class="bento-middle-column">
            <!-- 年份 -->
            <div class="bento-mid-row">
              <div class="bento-mid-row-inner anim-s4-card-unit">
                <div class="bento-mid-value-group">
                  <svg class="bento-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                  <span class="countdown-value" id="val-year">00</span>
                </div>
                <div class="bento-mid-label-group">
                  <span class="label-en">{yearEn}</span>
                  <span class="label-zh">{yearZh}</span>
                </div>
              </div>
            </div>
            
            <!-- 月份 -->
            <div class="bento-mid-row">
              <div class="bento-mid-row-inner anim-s4-card-unit">
                <div class="bento-mid-value-group">
                  <svg class="bento-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                  <span class="countdown-value" id="val-month">00</span>
                </div>
                <div class="bento-mid-label-group">
                  <span class="label-en">{monthEn}</span>
                  <span class="label-zh">{monthZh}</span>
                </div>
              </div>
            </div>
            
            <!-- 日份 -->
            <div class="bento-mid-row">
              <div class="bento-mid-row-inner anim-s4-card-unit">
                <div class="bento-mid-value-group">
                  <svg class="bento-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 16 14"></polyline></svg>
                  <span class="countdown-value" id="val-day">00</span>
                </div>
                <div class="bento-mid-label-group">
                  <span class="label-en">{dayEn}</span>
                  <span class="label-zh">{dayZh}</span>
                </div>
              </div>
            </div>
          </div>

          <!-- 右側 -->
          <div class="bento-card bento-right anim-s4-card-unit">
            <div class="station-clock-wrapper">
              <div class="flap-group">
                <div class="flap-card" id="card-h1">
                  <div class="card-half top"><div class="digit-inner">0</div></div>
                  <div class="card-half bottom"><div class="digit-inner">0</div></div>
                  <div class="flip-line"></div>
                </div>
                <div class="flap-card" id="card-h2">
                  <div class="card-half top"><div class="digit-inner">0</div></div>
                  <div class="card-half bottom"><div class="digit-inner">0</div></div>
                  <div class="flip-line"></div>
                </div>
              </div>
              <span class="clock-colon">:</span>
              <div class="flap-group">
                <div class="flap-card" id="card-m1">
                  <div class="card-half top"><div class="digit-inner">0</div></div>
                  <div class="card-half bottom"><div class="digit-inner">0</div></div>
                  <div class="flip-line"></div>
                </div>
                <div class="flap-card" id="card-m2">
                  <div class="card-half top"><div class="digit-inner">0</div></div>
                  <div class="card-half bottom"><div class="digit-inner">0</div></div>
                  <div class="flip-line"></div>
                </div>
              </div>
              <span class="clock-colon">:</span>
              <div class="flap-group">
                <div class="flap-card" id="card-s1">
                  <div class="card-half top"><div class="digit-inner">0</div></div>
                  <div class="card-half bottom"><div class="digit-inner">0</div></div>
                  <div class="flip-line"></div>
                </div>
                <div class="flap-card" id="card-s2">
                  <div class="card-half top"><div class="digit-inner">0</div></div>
                  <div class="card-half bottom"><div class="digit-inner">0</div></div>
                  <div class="flip-line"></div>
                </div>
              </div>
            </div>
            
            <div class="clock-caption">{ABOUT_CONFIG.retirement.clockCaption}</div>
            <div class="bento-divider"></div>
            
            <div class="bento-progress-anchor">
              <div class="progress-status-row">
                <span class="progress-mini-label">Total Era Progression</span>
                <span class="progress-percentage" id="progress-text">00.000000%</span>
              </div>
              <div class="progress-bar-track">
                <div class="progress-bar-fill" id="progress-bar-fill"></div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- 階段 5：技術棧矩陣 -->
    <section class="story-stage" id="stage-techstack">
      <div class="stage-inner flex-center">
        
        <div class="tech-content-holder anim-s5-title-fade">
          <h2 class="tech-main-header">{ABOUT_CONFIG.techStack.title}</h2>
          <p class="tech-main-sub">{ABOUT_CONFIG.techStack.subtitle}</p>
        </div>

        <div class="tech-tree-wrapper">
          <div class="tech-branch-node" id="tech-main-dot"></div>
          <svg class="tech-branch-svg" viewBox="0 0 800 60" fill="none">
            <path class="tech-line-path" id="tech-path-left" d="M 400,0 L 400,30 L 200,30 L 200,60" stroke-width="2" stroke-dasharray="260" stroke-dashoffset="260" />
            <path class="tech-line-path" id="tech-path-right" d="M 400,0 L 400,30 L 600,30 L 600,60" stroke-width="2" stroke-dasharray="260" stroke-dashoffset="260" />
          </svg>
        </div>

        <div class="tech-cards-matrix">
          <div class="tech-twin-card tech-card-left anim-s5-card-item">
            <div class="tech-inner-glow"></div>
            <svg class="tech-card-corner-logo" viewBox="0 0 85 107" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M27.5893 91.1365C22.7555 86.7178 21.3443 77.4335 23.3583 70.7072C26.8503 74.948 31.6888 76.2914 36.7005 77.0497C44.4374 78.2199 52.0358 77.7822 59.2231 74.2459C60.0453 73.841 60.8052 73.3027 61.7036 72.7574C62.378 74.714 62.5535 76.6892 62.3179 78.6996C61.7452 83.5957 59.3086 87.3778 55.4332 90.2448C53.8835 91.3916 52.2437 92.4167 50.6432 93.4979C45.7262 96.8213 44.3959 100.718 46.2435 106.386C46.2874 106.525 46.3267 106.663 46.426 107C43.9155 105.876 42.0817 104.24 40.6844 102.089C39.2086 99.8193 38.5065 97.3081 38.4696 94.5909C38.4511 93.2686 38.4511 91.9345 38.2733 90.6309C37.8391 87.4527 36.3471 86.0297 33.5364 85.9478C30.6518 85.8636 28.37 87.6469 27.7649 90.4554C27.7187 90.6707 27.6517 90.8837 27.5847 91.1341L27.5893 91.1365Z" fill="currentColor"/>
              <path d="M0 69.5866C0 69.5866 14.3139 62.6137 28.6678 62.6137L39.4901 29.1204C39.8953 27.5007 41.0783 26.3999 42.4139 26.3999C43.7495 26.3999 44.9325 27.5007 45.3377 29.1204L56.1601 62.6137C73.1601 62.6137 84.8278 69.5866 84.8278 69.5866C84.8278 69.5866 60.5145 3.35233 60.467 3.21944C59.7692 1.2612 58.5911 0 57.0029 0H27.8274C26.2392 0 25.1087 1.2612 24.3634 3.21944C24.3108 3.34983 0 69.5866 0 69.5866Z" fill="currentColor"/>
            </svg>
            <div class="tech-card-header-group">
              <span class="tech-card-meta-tag">{ABOUT_CONFIG.techStack.leftCard.tag}</span>
              <h3 class="tech-card-hero-title">
                {ABOUT_CONFIG.techStack.leftCard.title} <span class="tech-card-hero-zh">{ABOUT_CONFIG.techStack.leftCard.subTitle}</span>
              </h3>
              <div class="tech-card-framework-tag">{ABOUT_CONFIG.techStack.leftCard.framework}</div>
            </div>
            <div class="tech-card-body-group">
              <p class="tech-card-question">{ABOUT_CONFIG.techStack.leftCard.question}</p>
              <div class="tech-structured-doc blue-tint-doc">
                {ABOUT_CONFIG.techStack.contentLines?.left ? ABOUT_CONFIG.techStack.leftCard.contentLines.map((line) => (
                  <p class="doc-text-paragraph">{line}</p>
                )) : ABOUT_CONFIG.techStack.leftCard.contentLines.map((line) => (
                  <p class="doc-text-paragraph">{line}</p>
                ))}
              </div>
            </div>
          </div>

          <div class="tech-twin-card tech-card-right anim-s5-card-item">
            <div class="tech-inner-glow"></div>
            <svg class="tech-card-corner-logo gemini-logo-spark" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C12 7.523 16.477 12 22 12C16.477 12 12 16.477 12 22C12 16.477 7.523 12 2 12C7.523 12 12 7.523 12 2Z" />
            </svg>
            <div class="tech-card-header-group">
              <span class="tech-card-meta-tag">{ABOUT_CONFIG.techStack.rightCard.tag}</span>
              <h3 class="tech-card-hero-title">
                {ABOUT_CONFIG.techStack.rightCard.title} <span class="tech-card-hero-zh">{ABOUT_CONFIG.techStack.rightCard.subTitle}</span>
              </h3>
              <div class="tech-card-framework-tag">{ABOUT_CONFIG.techStack.rightCard.framework}</div>
            </div>
            <div class="tech-card-body-group">
              <p class="tech-card-question">{ABOUT_CONFIG.techStack.rightCard.question}</p>
              <div class="tech-structured-doc white-tint-doc">
                {ABOUT_CONFIG.techStack.rightCard.contentLines.map((line) => (
                  <p class="doc-text-paragraph">{line}</p>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 階段 6：聯繫我 -->
    <section class="story-stage" id="stage-contact">
      <div class="stage-inner flex-center">
        
        <div class="contact-content-holder">
          <h2 class="contact-main-header">{ABOUT_CONFIG.contact.title}</h2>
          <p class="contact-main-sub">{ABOUT_CONFIG.contact.subtitle}</p>
        </div>

        <div class="contact-layout-container">
          <div class="social-links-grid">
            {ABOUT_CONFIG.contact.links.map((link) => (
              <a href={link.url} target="_blank" rel="noopener noreferrer" class="social-glass-card anim-s6-card">
                <div class="social-icon-wrapper" set:html={link.iconSvg}></div>
                <span class="social-name">{link.name}</span>
              </a>
            ))}
          </div>

          <div class="wechat-reward-card anim-s6-reward">
            <div class="reward-inner-glow"></div>
            <div class="qr-code-wrapper">
              {ABOUT_CONFIG.contact.wechatRewardImg ? (
                <img src={ABOUT_CONFIG.contact.wechatRewardImg} alt="微信贊賞碼" class="qr-code-img" />
              ) : (
                <div class="qr-placeholder">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><rect x="7" y="7" width="3" height="3"></rect><rect x="14" y="7" width="3" height="3"></rect><rect x="7" y="14" width="3" height="3"></rect><line x1="14" y1="14" x2="14" y2="14.01"></line><line x1="17" y1="14" x2="17" y2="14.01"></line><line x1="14" y1="17" x2="17" y2="17"></line>
                  </svg>
                  <span>未配置贊賞碼</span>
                </div>
              )}
            </div>
            <div class="reward-caption">微信贊賞碼 / Reward QR</div>
          </div>
        </div>
      </div>
    </section>

    <!-- 懸浮 Dock 導航島 -->
    <div class="floating-dock-island">
      <div class="dock-blur-bg"></div>
      <div class="dock-buttons-row">
        {ABOUT_CONFIG.dockLabels.map((item, index) => (
          <button class={index === 0 ? "dock-btn active" : "dock-btn"} data-target={item.target}>
            <span class="dot"></span><span class="label">{item.label}</span>
          </button>
        ))}
      </div>
    </div>

  </main>

</body>
</html>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>
<script is:inline define:vars={{ defaultStart: ABOUT_CONFIG.retirement.startDate, defaultTarget: ABOUT_CONFIG.retirement.targetDate }}>
  document.addEventListener('astro:page-load', () => {
    const viewport = document.querySelector('.about-cinematic-viewport');
    if (viewport) viewport.classList.remove('opacity-0');

    // 低性能模式对接监听
    window.addEventListener('sinyan-perf-status', (e) => {
      const { status } = e.detail || {};
      if (status === 'degraded') {
        document.documentElement.classList.add('perf-degraded');
      } else if (status === 'high') {
        document.documentElement.classList.remove('perf-degraded');
      }
    });

    let currentStage = 0;
    const stages = [
      document.getElementById('stage-capabilities'),
      document.getElementById('stage-mosaic'),
      document.getElementById('stage-deepdive'),
      document.getElementById('stage-retirement'),
      document.getElementById('stage-techstack'),
      document.getElementById('stage-contact')
    ];
    const dockButtons = document.querySelectorAll('.dock-btn');

    const retirementSection = document.getElementById('stage-retirement');
    const targetDateStr = retirementSection?.dataset.targetDate || defaultTarget;
    const startDateStr = retirementSection?.dataset.startDate || defaultStart;
    
    const targetDate = new Date(targetDateStr);
    const startDate = new Date(startDateStr); 
    const totalTimeSpan = targetDate - startDate;

    function setFlapDigitWithAnimation(cardId, newValue) {
      const card = document.getElementById(cardId);
      if (!card) return;
      const topInner = card.querySelector('.top .digit-inner');
      const bottomInner = card.querySelector('.bottom .digit-inner');

      if (topInner.textContent === newValue) return;

      gsap.killTweensOf(card);
      topInner.textContent = newValue;
      bottomInner.textContent = newValue;
      
      gsap.fromTo(card, 
        { rotationX: 45, transformOrigin: "center top" }, 
        { rotationX: 0, duration: 0.28, ease: "back.out(3.5)", clearProps: "transform" }
      );
    }

    function updateCountdown() {
      const now = new Date();
      const diffTime = targetDate - now;
      if (diffTime <= 0) return;

      let years = targetDate.getFullYear() - now.getFullYear();
      let months = targetDate.getMonth() - now.getMonth();
      let days = targetDate.getDate() - now.getDate();

      if (days < 0) {
        months -= 1;
        const previousMonth = new Date(now.getFullYear(), now.getMonth(), 0);
        days += previousMonth.getDate();
      }
      if (months < 0) {
        years -= 1;
        months += 12;
      }

      const rHours = String(23 - now.getHours()).padStart(2, '0');
      const rMinutes = String(59 - now.getMinutes()).padStart(2, '0');
      const rSeconds = String(59 - now.getSeconds()).padStart(2, '0');

      const yEl = document.getElementById('val-year');
      const mEl = document.getElementById('val-month');
      const dEl = document.getElementById('val-day');
      if (yEl) yEl.textContent = String(years).padStart(2, '0');
      if (mEl) mEl.textContent = String(months).padStart(2, '0');
      if (dEl) dEl.textContent = String(days).padStart(2, '0');

      setFlapDigitWithAnimation('card-h1', rHours[0]);
      setFlapDigitWithAnimation('card-h2', rHours[1]);
      setFlapDigitWithAnimation('card-m1', rMinutes[0]);
      setFlapDigitWithAnimation('card-m2', rMinutes[1]);
      setFlapDigitWithAnimation('card-s1', rSeconds[0]);
      setFlapDigitWithAnimation('card-s2', rSeconds[1]);
    }

    function renderHighPrecisionProgress() {
      const now = new Date();
      const elapsedTime = now - startDate;
      let currentPercent = (elapsedTime / totalTimeSpan) * 100;
      
      if (currentPercent > 100) currentPercent = 100;
      if (currentPercent < 0) currentPercent = 0;

      const progressText = document.getElementById('progress-text');
      const progressBarFill = document.getElementById('progress-bar-fill');

      if (progressText) progressText.textContent = currentPercent.toFixed(6) + '%';
      if (progressBarFill) progressBarFill.style.width = currentPercent + '%';

      if (document.querySelector('.about-cinematic-viewport')) {
        requestAnimationFrame(renderHighPrecisionProgress);
      }
    }

    if (window._aboutCountdownTimer) clearInterval(window._aboutCountdownTimer);
    window._aboutCountdownTimer = setInterval(updateCountdown, 1000);
    
    updateCountdown();
    requestAnimationFrame(renderHighPrecisionProgress);

    animateStage0In();

    function animateStage0In() {
      gsap.set([".anim-s1-avatar", ".anim-s1-title", ".anim-s1-card", ".anim-s1-claim"], { clearProps: "all" });
      gsap.timeline()
        .fromTo(".anim-s1-avatar", { opacity: 0, scale: 0.4, y: 35 }, { opacity: 1, scale: 1, y: 0, duration: 1.1, ease: "back.out(1.4)" })
        .fromTo(".anim-s1-title", { opacity: 0, y: 40 }, { opacity: 1, y: 0, duration: 0.9, ease: "expo.out" }, "-=0.8")
        .fromTo(".anim-s1-card", { opacity: 0, y: 45, scale: 0.96 }, { opacity: 1, y: 0, scale: 1, stagger: 0.06, duration: 1.0, ease: "back.out(1.3)" }, "-=0.6")
        .fromTo(".anim-s1-claim", { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.8, ease: "power3.out" }, "-=0.45");
    }

    function initDragEngine() {
      document.querySelectorAll('.mosaic-drag-card').forEach(card => {
        let isDragging = false;
        card.addEventListener('mousedown', (e) => {
          e.preventDefault(); isDragging = true; card.style.cursor = 'grabbing'; card.style.zIndex = '100'; 
          let transformX = gsap.getProperty(card, "x") || 0;
          let transformY = gsap.getProperty(card, "y") || 0;
          const startX = e.clientX - transformX; const startY = e.clientY - transformY;
          const onMouseMove = (ev) => {
            if (!isDragging) return;
            transformX = ev.clientX - startX; transformY = ev.clientY - startY;
            gsap.set(card, { x: transformX, y: transformY, scale: 1.04, rotation: parseFloat(card.getAttribute('data-rot')) || 0 });
          };
          const onMouseUp = () => {
            isDragging = false; card.style.cursor = 'grab'; card.style.zIndex = '5'; gsap.set(card, { scale: 1 });
            document.removeEventListener('mousemove', onMouseMove); document.removeEventListener('mouseup', onMouseUp);
          };
          document.addEventListener('mousemove', onMouseMove); document.addEventListener('mouseup', onMouseUp);
        });
      });
    }

    initDragEngine();

    function switchStage(targetIndex) {
      if (targetIndex === currentStage) return;
      const outboundSection = stages[currentStage];
      const inboundSection = stages[targetIndex];

      const dock = document.querySelector('.floating-dock-island');
      if (dock) dock.style.pointerEvents = 'none';

      dockButtons.forEach((btn, idx) => btn.classList.toggle('active', idx === targetIndex));
      
      const transitionTimeline = gsap.timeline({
        onComplete: () => {
          if (dock) dock.style.pointerEvents = 'auto';
        }
      });

      if (currentStage === 0) {
        transitionTimeline.to([".anim-s1-avatar", ".anim-s1-title", ".anim-s1-card", ".anim-s1-claim"], { opacity: 0, y: -30, scale: 0.95, stagger: 0.02, duration: 0.3, ease: "power3.in" });
      } else if (currentStage === 1) {
        transitionTimeline.to(".mosaic-content-holder", { opacity: 0, y: -15, duration: 0.2 })
                          .to(".mosaic-drag-card", { opacity: 0, scale: 0.75, y: -25, stagger: 0.02, duration: 0.25, ease: "power3.in" }, "-=0.15");
      } else if (currentStage === 2) {
        transitionTimeline.to(".pillar-glass-block", { opacity: 0, y: -25, stagger: 0.02, duration: 0.25, ease: "power3.in" })
                          .to(".deepdive-content-holder, .spotlight-container", { opacity: 0, duration: 0.2 }, "-=0.15");
      } else if (currentStage === 3) {
        transitionTimeline.to([".anim-s4-title-fade", ".anim-s4-card-unit"], { opacity: 0, duration: 0.25, ease: "power2.in" });
      } else if (currentStage === 4) {
        transitionTimeline.to([".anim-s5-title-fade", ".tech-tree-wrapper", ".anim-s5-card-item"], { opacity: 0, duration: 0.25, ease: "power2.in" });
      } else if (currentStage === 5) {
        transitionTimeline.to(".contact-content-holder", { opacity: 0, y: -15, duration: 0.2 })
                          .to([".anim-s6-card", ".anim-s6-reward"], { opacity: 0, duration: 0.2 }, "-=0.15")
                          .to([".anim-s6-card .social-icon-wrapper", ".anim-s6-card .social-name", ".anim-s6-reward .qr-code-wrapper", ".anim-s6-reward .reward-caption"], { opacity: 0, y: -20, duration: 0.2 }, "-=0.2");
      }

      transitionTimeline.add(() => {
        if (outboundSection) outboundSection.classList.remove('active');
        gsap.set(outboundSection, { clearProps: "all" });
        if (inboundSection) inboundSection.classList.add('active');
      });

      if (targetIndex === 0) {
        transitionTimeline.fromTo(".anim-s1-avatar", { opacity: 0, scale: 0.4, y: 35 }, { opacity: 1, scale: 1, y: 0, duration: 0.6, ease: "back.out(1.4)" })
                          .fromTo(".anim-s1-title", { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.5, ease: "power3.out" }, "-=0.4")
                          .fromTo(".anim-s1-card", { opacity: 0, y: 35, scale: 0.96 }, { opacity: 1, y: 0, scale: 1, stagger: 0.04, duration: 0.6, ease: "back.out(1.3)" }, "-=0.3")
                          .fromTo(".anim-s1-claim", { opacity: 0, y: 15 }, { opacity: 1, y: 0, duration: 0.4, ease: "power3.out" }, "-=0.25");
      } 
      else if (targetIndex === 1) {
        transitionTimeline.fromTo(".mosaic-content-holder", { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.5, ease: "power3.out" })
                          .fromTo(".mosaic-drag-card", { opacity: 0, scale: 0.8, y: 30, rotation: 0 }, { opacity: 1, scale: 1, y: 0, rotation: (i, t) => parseFloat(t.getAttribute('data-rot')) || 0, stagger: 0.04, duration: 0.7, ease: "back.out(1.2)" }, "-=0.35");
      } 
      else if (targetIndex === 2) {
        transitionTimeline.fromTo(".spotlight-container", { opacity: 0 }, { opacity: 1, duration: 0.25 })
                          .fromTo("#spotlight-1", { x: 0, scale: 0.7 }, { x: -window.innerWidth * 0.28, scale: 1, duration: 0.7, ease: "power3.out" }, "-=0.25")
                          .fromTo("#spotlight-3", { x: 0, scale: 0.7 }, { x: window.innerWidth * 0.28, scale: 1, duration: 0.7, ease: "power3.out" }, "-=0.7")
                          .fromTo(".spotlight", { opacity: 0 }, { opacity: 0.45, stagger: 0.03, duration: 0.5, ease: "power2.out" }, "-=0.5")
                          .fromTo(".deepdive-content-holder", { opacity: 0, y: 15 }, { opacity: 1, y: 0, duration: 0.4, ease: "power3.out" }, "-=0.4")
                          .fromTo(".pillar-glass-block", { opacity: 0, y: 30, scale: 0.97 }, { opacity: 1, y: 0, scale: 1, stagger: 0.05, duration: 0.65, ease: "back.out(1.2)" }, "-=0.25");
      }
      else if (targetIndex === 3) {
        transitionTimeline.fromTo(".anim-s4-title-fade", { opacity: 0, y: 15 }, { opacity: 1, y: 0, duration: 0.5, ease: "power3.out" })
                          .fromTo(".anim-s4-card-unit", { opacity: 0, y: 10 }, { opacity: 1, y: 0, duration: 0.6, ease: "power2.out", clearProps: "all" }, "-=0.35");
      }
      else if (targetIndex === 4) {
        transitionTimeline.add(() => {
          gsap.set(".tech-tree-wrapper", { opacity: 1 });
          gsap.set(["#tech-path-left", "#tech-path-right"], { strokeDasharray: 260, strokeDashoffset: 260, opacity: 1 });
          gsap.set("#tech-main-dot", { scale: 0, opacity: 0 });
          gsap.set(".anim-s5-card-item", { opacity: 0, y: 10 });
        })
        .fromTo(".anim-s5-title-fade", { opacity: 0, y: 15 }, { opacity: 1, y: 0, duration: 0.45, ease: "power3.out" })
        .fromTo("#tech-main-dot", { scale: 0, opacity: 0 }, { scale: 1, opacity: 1, duration: 0.35, ease: "back.out(2)" }, "-=0.2")
        .fromTo("#tech-path-left", { strokeDashoffset: 260 }, { strokeDashoffset: 0, duration: 0.55, ease: "power2.inOut" }, "-=0.05")
        .fromTo("#tech-path-right", { strokeDashoffset: 260 }, { strokeDashoffset: 0, duration: 0.55, ease: "power2.inOut" }, "<")
        .fromTo(".anim-s5-card-item", { opacity: 0, y: 8 }, { opacity: 1, y: 0, duration: 0.55, ease: "power2.out", clearProps: "all" }, "-=0.25");
      }
      else if (targetIndex === 5) {
        transitionTimeline.fromTo(".contact-content-holder", { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.5, ease: "power3.out" })
                          .fromTo([".anim-s6-card", ".anim-s6-reward"], { opacity: 0 }, { opacity: 1, duration: 0.4, ease: "power2.out" }, "-=0.3")
                          .fromTo([".anim-s6-card .social-icon-wrapper", ".anim-s6-card .social-name", ".anim-s6-reward .qr-code-wrapper", ".anim-s6-reward .reward-caption"],
                            { opacity: 0, y: 25 },
                            { opacity: 1, y: 0, stagger: 0.02, duration: 0.65, ease: "back.out(1.3)" },
                            "-=0.25"
                          );
      }

      currentStage = targetIndex;
    }

    dockButtons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        switchStage(parseInt(e.currentTarget.dataset.target, 10));
      });
    });
  });
</script>

