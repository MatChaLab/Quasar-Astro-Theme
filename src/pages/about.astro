---
import { SITE_CONFIG, ABOUT_CONFIG } from '../config';
import Navbar from '../components/Navbar.astro';
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About | {SITE_CONFIG.title}</title>
</head>
<body>
  <Navbar />

  <main class="about-viewport">
    <div class="content-wrapper">
      
      <section class="hero anim-item">
        <img src={ABOUT_CONFIG.avatar.src} alt={ABOUT_CONFIG.avatar.alt} class="avatar-img" />
        <h1 class="hero-title">{ABOUT_CONFIG.name}</h1>
        <p class="hero-subtitle">{ABOUT_CONFIG.subtitle}</p>
        
        <!-- 社交链接 -->
        <div class="social-links">
          {ABOUT_CONFIG.socialLinks.map(link => (
            <a href={link.url} target="_blank" class="social-icon" aria-label={link.name} set:html={link.icon} />
          ))}
        </div>
      </section>

      <section class="bio anim-item">
        {ABOUT_CONFIG.bio.map(p => <p>{p}</p>)}
      </section>

      <section class="grid-container">
        {ABOUT_CONFIG.interests.map(item => (
          <div class="glass-card anim-item">
            <h3>{item.title}</h3>
            <p set:html={item.desc} />
          </div>
        ))}
      </section>

    </div>
  </main>
</body>
</html>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>
<script is:inline>
  // 🔴 优雅的非线性动画：stagger 错落入场，back.out 制造轻微回弹效果
  gsap.from(".anim-item", {
    y: 40,
    opacity: 0,
    duration: 1.2,
    ease: "back.out(1.2)",
    stagger: 0.15
  });
</script>

<style>
  :global(body) { background-color: #030303; color: #ffffff; margin: 0; font-family: 'Noto Sans SC', sans-serif; }

  .about-viewport { padding: 160px 10% 100px 10%;  }
  .content-wrapper { max-width: 100rem; margin: 0 auto; }
  
  .hero { text-align: left; margin-bottom: 80px; }
  .avatar-img { width: 100px; height: 100px; border-radius: 28px; margin-bottom: 24px; object-fit: cover; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
  
  .hero-title { font-size: 4rem; font-weight: 900; letter-spacing: -0.05em; margin: 0; }
  .hero-subtitle { font-size: 1.2rem; color: #888; margin-top: 8px; }
  
  .social-links { display: flex; gap: 20px; margin-top: 24px; }
  .social-icon { width: 24px; height: 24px; color: #666; transition: all 0.3s ease; }
  .social-icon:hover { color: #fff; transform: translateY(-3px); }

  .bio { font-size: 1.1rem; line-height: 1.8; color: #ccc; margin-bottom: 80px; }
  
  .grid-container { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
  .glass-card { padding: 32px; border-radius: 24px; background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.05); }
  .glass-card h3 { font-size: 1rem; margin-top: 0; color: #888; }
  .glass-card p { font-size: 0.9rem; color: #999; line-height: 1.5; margin-bottom: 0; }
  
.glass-card { 
    padding: 32px; 
    border-radius: 24px; 
    /* 1. 更细腻的背景透明度 */
    background: rgba(255, 255, 255, 0.04); 
    /* 2. 增加微小内边框，制造高光感 */
    border: 1px solid rgba(255, 255, 255, 0.1); 
    /* 3. 极淡的内部高光，让边缘不那么死板 */
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.4s ease;
  }

  .glass-card:hover { 
    transform: translateY(-8px) scale(1.02); 
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.2);
  }

  /* 🔴 亮色模式下的质感升级 */
  :global(.light-mode) .glass-card { 
    background: rgba(255, 255, 255, 0.6); 
    border: 1px solid rgba(0, 0, 0, 0.05); 
  }
  :global(.light-mode) .glass-card:hover {
    background: rgba(255, 255, 255, 0.8);
  }
</style>
