---
// src/pages/index.astro
import { SITE_CONFIG } from '../config.ts';
import Intro from '../components/Intro.astro';
import Earth from '../components/Earth.astro';
import Navbar from '../components/Navbar.astro';
import { ClientRouter } from 'astro:transitions';
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{SITE_CONFIG.title}</title>
    
    <!-- 載入 Noto Sans SC 與 Plus Jakarta Sans 字型 -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@100;400;700;900&family=Plus+Jakarta+Sans:wght@300;900&display=swap" rel="stylesheet">
    
    <!-- 全局核心：啟用 Astro 5+ 原生 ClientRouter 檢視過渡引擎 -->
    <ClientRouter />

    <!-- 主題狀態持久化守衛：防止無刷新路由切換時產生視覺閃爍 -->
    <script is:inline>
      const syncSystemTheme = () => {
        if (localStorage.getItem('theme') === 'light') {
          document.documentElement.classList.add('light-mode');
        } else {
          document.documentElement.classList.remove('light-mode');
        }
      };
      // 初始化加載時執行
      syncSystemTheme();
      // 在 ClientRouter 頁面完成替換後獨立同步狀態
      document.addEventListener('astro:after-swap', syncSystemTheme);
    </script>
  </head>
  <body>

    <!-- 1. 開屏物理動畫組件 -->
    <Intro />

    <!-- 2. 主視口容器 -->
    <div class="main-viewport">
      
      <!-- 頂部液態玻璃導航欄組件 -->
      <Navbar />

      <!-- 3D 地球渲染島組件（使用 transition:persist 保持 Canvas 上下文持久化） -->
      <Earth transition:persist="earth-canvas" />

      <!-- 中央核心資訊層 -->
      <div class="hero-container">
        <!-- 左側：品牌標題與副標題 -->
        <div class="title-group">
          <h1 class="main-title anim-title-item">{SITE_CONFIG.logo}</h1>
          <p class="subtitle anim-title-item">{SITE_CONFIG.subtitle}</p>
        </div>

        <!-- 右側：工作室詳情卡片 -->
        <div class="studio-card anim-studio-card">
          <p class="studio-title">©2026 {SITE_CONFIG.copyRight}</p>
          <ul class="studio-details">
            <li><span class="red-star">*</span> {SITE_CONFIG.redStar1}</li>
            <li><span class="red-star">*</span> {SITE_CONFIG.redStar2}</li>
            <li><span class="red-star">*</span> {SITE_CONFIG.redStar3}</li>
          </ul>
        </div>
      </div>

      <!-- 底部左側個人敘事區塊 -->
      <div class="footer-caption">
        <!-- 第一行：标签 -->
        <p class="bio-tagline anim-tagline-item">
          <span class="blue-dot"></span> {SITE_CONFIG.bioHeader}
        </p>
        <!-- 第二行：主标题（逐字动画目标） -->
        <h2 class="bio-title" id="bio-title-el">{SITE_CONFIG.bioTitle}</h2>
        <!-- 第三行：描述文字（逐字动画目标） -->
        <p class="bio-desc" id="bio-desc-el">{SITE_CONFIG.bioDesc}</p>
      </div>

    </div>

    <!-- GSAP 核心动画引擎 -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>

    <script is:inline>
      document.addEventListener('astro:page-load', () => {
        const titleItems = document.querySelectorAll('.anim-title-item');
        const taglineItem = document.querySelector('.anim-tagline-item');
        const studioCard = document.querySelector('.anim-studio-card');
        
        const bioTitleEl = document.getElementById('bio-title-el');
        const bioDescEl = document.getElementById('bio-desc-el');

        if (!titleItems.length) return;

        // 🟢 将文本拆分为逐字 span 节点的辅助函数
        const splitTextToChars = (el) => {
          if (!el) return [];
          const rawText = el.textContent.trim();
          el.innerHTML = '';
          const charSpans = [];
          
          Array.from(rawText).forEach(char => {
            const span = document.createElement('span');
            span.className = 'char-span';
            span.textContent = char;
            el.appendChild(span);
            charSpans.push(span);
          });
          return charSpans;
        };

        const titleChars = splitTextToChars(bioTitleEl);
        const descChars = splitTextToChars(bioDescEl);

        // 电影级分步梯队入场动画
        const runCinematicEntrance = () => {
          gsap.killTweensOf([titleItems, taglineItem, titleChars, descChars, studioCard]);

          const tl = gsap.timeline({
            defaults: { ease: "power3.out" }
          });

          // 1️⃣ 第一阶段：左上标题与副标题（由模糊逐渐凝聚、轻盈浮现）
          tl.fromTo(
            titleItems,
            { opacity: 0, y: 50, filter: "blur(10px)" },
            {
              opacity: 1,
              y: 0,
              filter: "blur(0px)",
              duration: 1.3,
              stagger: 0.16,
              clearProps: "transform,filter"
            }
          )
          // 2️⃣ 第二阶段：左下角第 1 行标签
          .fromTo(
            taglineItem,
            { opacity: 0, y: 25, filter: "blur(4px)" },
            {
              opacity: 1,
              y: 0,
              filter: "blur(0px)",
              duration: 0.9,
              clearProps: "transform,filter"
            },
            "-=0.8"
          )
          // 3️⃣ 第三阶段：左下角第 2 行标题（一个字一个字显现）
          .fromTo(
            titleChars,
            { opacity: 0, y: 15, filter: "blur(5px)" },
            {
              opacity: 1,
              y: 0,
              filter: "blur(0px)",
              duration: 0.45,
              stagger: 0.04, // 字与字之间的间隔时间
              ease: "power2.out",
              clearProps: "transform,filter"
            },
            "-=0.5"
          )
          // 4️⃣ 第四阶段：左下角第 3 行描述（一个字一个字显现，节奏略快）
          .fromTo(
            descChars,
            { opacity: 0, y: 12, filter: "blur(4px)" },
            {
              opacity: 1,
              y: 0,
              filter: "blur(0px)",
              duration: 0.35,
              stagger: 0.018, // 描述文字较多，适当加快逐字速率
              ease: "power1.out",
              clearProps: "transform,filter"
            },
            "-=0.2"
          )
          // 5️⃣ 第五阶段：右侧工作室卡片压轴亮相
          .fromTo(
            studioCard,
            { opacity: 0, y: 35, filter: "blur(8px)" },
            {
              opacity: 1,
              y: 0,
              filter: "blur(0px)",
              duration: 1.2,
              clearProps: "transform,filter"
            },
            "-=0.5"
          );
        };

        // 状态判断：若开屏动画已播放过或二次切回首页，直接播放动画
        if (window._introHasPlayed) {
          runCinematicEntrance();
        } else {
          // 首次加载先隐去节点，等开屏吞噬动画完成事件唤醒
          gsap.set([titleItems, taglineItem, titleChars, descChars, studioCard], { opacity: 0 });
          window.addEventListener('intro-complete', runCinematicEntrance, { once: true });
        }
      });
    </script>

  </body>
</html>

<style>
  /* =========================================
     核心布局樣式
     ========================================= */
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html, body {
    background-color: #030303;
    color: #ffffff;
    font-family: 'Noto Sans SC', -apple-system, BlinkMacSystemFont, sans-serif;
    overflow: hidden; /* 嚴禁出現全局滾動條 */
  }

  .main-viewport {
    position: relative;
    width: 100vw;
    height: 100vh;
  }

  /* 中央資訊容器 */
  .hero-container {
    position: absolute;
    top: 55%;
    left: 4%;
    right: 6%;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 2;
    pointer-events: none; /* 穿透鼠標以保證背景地球可進行 3D 拖拽交互 */
  }

  .title-group {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* 主標題鈦金屬漸變 */
  .main-title {
    font-weight: 900;
    font-size: 10.618rem;
    line-height: 1.25;
    letter-spacing: -0.05em;
    background: linear-gradient(180deg, #ffffff 60%, #999999 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    will-change: transform, opacity, filter;
  }

  /* 極細副標題 */
  .subtitle {
    font-weight: 200;
    font-size: 2.618rem;
    margin-top: 16px;
    letter-spacing: 0.05em;
    color: #cccccc;
    padding-left: 6px;
    will-change: transform, opacity, filter;
  }

  /* 右側工作室卡片 */
  .studio-card {
    max-width: 380px;
    color: #ffffff;
    text-align: left;
    margin-top: 50px;
    pointer-events: auto; /* 恢復卡片內部交互 */
    will-change: transform, opacity, filter;
  }

  .studio-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 900;
    font-size: 1rem;
    letter-spacing: 0.05em;
    margin-bottom: 16px;
  }

  .studio-details {
    list-style: none;
    font-size: 0.8rem;
    color: #aaaaaa;
    line-height: 2;
  }

  .red-star {
    color: #ff3e18;
    font-weight: bold;
    margin-right: 6px;
  }

  /* 底部左側敘事面板 */
  .footer-caption {
    position: absolute;
    bottom: 40px;
    left: 4%;
    z-index: 2;
    padding: 0;
    max-width: 480px;
    pointer-events: none;
  }

  .bio-tagline {
    font-size: 0.9rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #888888;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
    will-change: transform, opacity, filter;
  }

  .blue-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    background-color: #102ea0;
    border-radius: 50%;
  }

  .bio-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 10px;
    letter-spacing: 0.02em;
    word-break: break-word;
  }

  .bio-desc {
    font-size: 0.95rem;
    color: #777777;
    line-height: 1.6;
    word-break: break-word;
  }

  /* 🟢 单字容器，确保空格和排版不塌陷 */
  :global(.char-span) {
    display: inline-block;
    white-space: pre;
    will-change: transform, opacity, filter;
  }

  /* 響應式佈局適配 */
  @media (max-width: 900px) {
    .main-title { font-size: 4.5rem; }
    .subtitle { font-size: 1.4rem; }
    .hero-container {
      flex-direction: column;
      align-items: flex-start;
      gap: 30px;
      left: 5%;
      top: 45%;
    }
    .studio-card { margin-top: 0; }
    .footer-caption { left: 5%; bottom: 20px; }
  }

  /* =========================================
     白晝模式樣式翻轉 (Light Mode)
     ========================================= */
  :global(html.light-mode) body {
    background-color: #f5f5f7 !important;
    color: #1d1d1f !important;
  }
  
  /* 主標題：轉換為高級鈦灰色漸變 */
  :global(html.light-mode) .main-title {
    background: linear-gradient(180deg, #1d1d1f 40%, #86868b 100%) !important;
    -webkit-background-clip: text !important;
    -webkit-text-fill-color: transparent !important;
  }
  
  /* 副標題與描述文字變更為深灰色 */
  :global(html.light-mode) .subtitle,
  :global(html.light-mode) .studio-details,
  :global(html.light-mode) .bio-desc,
  :global(html.light-mode) .bio-tagline {
    color: #86868b !important;
  }

  /* 文字卡片與小標題轉換為深黑色 */
  :global(html.light-mode) .studio-card,
  :global(html.light-mode) .bio-title {
    color: #1d1d1f !important;
  }
</style>