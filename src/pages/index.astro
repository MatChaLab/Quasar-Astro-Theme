---
// src/pages/index.astro
// Frontmatter 部分保持原样，无需修改
import { SITE_CONFIG } from '../config';
import Intro from '../components/Intro.astro';
import Earth from '../components/Earth.astro';
import Navbar from '../components/Navbar.astro';
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{SITE_CONFIG.title}</title>
    
    <!-- 统一载入 Noto Sans SC 字族与高级雅加达几何体 -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@100;400;700;900&family=Plus+Jakarta+Sans:wght@300;900&display=swap" rel="stylesheet">
  </head>
  <body>

    <!-- 1. 德芙级物理开屏动画 -->
    <Intro />

    <!-- 2. 主首页 -->
    <div class="main-viewport">
      
      <!-- 顶部液态玻璃导航栏 -->
      <Navbar />

      <!-- NASA 极清 3D 地球 -->
      <Earth />

      <!-- 两侧文字信息层 -->
      <div class="hero-container">
        <!-- 左侧：Sinyan 大标题与副标题 -->
        <div class="title-group">
          <h1 class="main-title">{SITE_CONFIG.logo}</h1>
          <p class="subtitle">{SITE_CONFIG.subtitle}</p>
        </div>

        <!-- 右侧：高档工作室详情卡片 -->
        <div class="studio-card">
          <p class="studio-title">©2026 {SITE_CONFIG.copyRight}</p>
          <ul class="studio-details">
            <li><span class="red-star">*</span> {SITE_CONFIG.redStar1}</li>
            <li><span class="red-star">*</span> {SITE_CONFIG.redStar2}</li>
            <li><span class="red-star">*</span> {SITE_CONFIG.redStar3}</li>
          </ul>
        </div>
      </div>

      <!-- 底部左侧信息叙事 (Bug 修复目标) -->
      <div class="footer-caption">
        <p class="bio-tagline">
          <span class="blue-dot"></span> {SITE_CONFIG.bioHeader}
        </p>
        <h2 class="bio-title">{SITE_CONFIG.bioTitle}</h2>
        <p class="bio-desc">{SITE_CONFIG.bioDesc}</p>
      </div>

    </div>

  </body>
</html>

<!-- 🔴 CSS 修复区块 -->
<style>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    background-color: #030303; /* 全局深邃黑 */
    color: #ffffff;
    /* 默认使用 Noto Sans SC，保证中文高级感 */
    font-family: 'Noto Sans SC', -apple-system, BlinkMacSystemFont, sans-serif;
    overflow: hidden; /* 严禁出现滚动条 */
  }

  .main-viewport {
    position: relative;
    width: 100vw;
    height: 100vh;
    /* 🔴 Bug 修复 1：移除之前的 Flexbox 布局 */
    /* 因为内部充满了绝对定位元素，Flexbox 无法正确计算空间分配 */
  }

  /* 中央 Hero 信息层 */
  .hero-container {
    position: absolute;
    top: 55%; /* 物理重心稍微偏下 */
    left: 4%; /* 保持呼吸感边距 */
    right: 6%;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 2; /* 浮在地球之上 */
    pointer-events: none; /* 穿透鼠标，保证地球可拖拽 */
  }

  .title-group {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* 银灰色渐变 Sinyan */
  .main-title {
    font-weight: 900;
    font-size: 10.618rem;
    line-height: 1.25;
    letter-spacing: -0.05em;
    /* 银灰色渐变，高雅冷酷 */
    background: linear-gradient(180deg, #ffffff 60%, #999999 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* 极细副标题 */
  .subtitle {
    font-weight: 200;
    font-size: 2.618rem;
    margin-top: 16px;
    letter-spacing: 0.05em;
    color: #cccccc;
    padding-left: 6px;
  }

  /* 右侧工作室卡片 */
  .studio-card {
    max-width: 380px;
    color: #ffffff;
    text-align: left;
    margin-top: 50px;
    pointer-events: auto; /* 恢复交互，如果将来有链接 */
  }

  .studio-title {
    /* 标题使用 Jakarta，增加几何几何感 */
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 900;
    font-size: 1rem;
    letter-spacing: 0.05em;
    margin-bottom: 16px;
  }

  .studio-details {
    list-style: none;
    font-size: 0.8rem;
    color: #aaaaaa;
    line-height: 2;
  }

  .red-star {
    color: #ff3e18; /* 亮橙色星星 */
    font-weight: bold;
    margin-right: 6px;
  }

  /* 底部左侧信息叙事 */
  .footer-caption {
    /* 🔴 Bug 修复 2：彻底改为绝对定位，钉在左下角 */
    position: absolute;
    bottom: 40px; /* 离底部边距 */
    left: 4%;    /* 🟢 物理修正：与 Hero 大标题 Sinyan 左侧严格垂直对齐 */
    z-index: 2;
    padding: 0;   /* 清除之前的 Padding */
    max-width: 480px;
    pointer-events: none;
  }

  .bio-tagline {
    font-size: 0.9rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #888888;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .blue-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    background-color: #102ea0; /* 深邃蓝点 */
    border-radius: 50%;
  }

  .bio-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 10px;
    letter-spacing: 0.02em;
  }

  .bio-desc {
    font-size: 0.95rem;
    color: #777777;
    line-height: 1.6;
  }

  /* 响应式媒体查询保持不变 */
  @media (max-width: 900px) {
    .main-title { font-size: 4.5rem; }
    .subtitle { font-size: 1.4rem; }
    .hero-container {
      flex-direction: column;
      align-items: flex-start;
      gap: 30px;
      left: 5%;
      top: 45%;
    }
    .studio-card { margin-top: 0; }
    .footer-caption { left: 5%; bottom: 20px; }
  }


  /* =========================================
     🔴 修复：白昼模式 (Light Mode) 强制翻转主页文字
     使用 :global 彻底打破 Astro 的作用域隔离
  ========================================= */
  
  :global(html.light-mode) body {
    background-color: #f5f5f7 !important; /* Apple 标志性冷白底色 */
    color: #1d1d1f !important;
  }
  
  /* Sinyan 巨大主标题：转换为高级太空灰金属渐变 */
  :global(html.light-mode) .main-title {
    background: linear-gradient(180deg, #1d1d1f 40%, #86868b 100%) !important;
    -webkit-background-clip: text !important;
    -webkit-text-fill-color: transparent !important;
  }
  
  /* 所有的副标题与描述文字：转换为深邃的高级灰 */
  :global(html.light-mode) .subtitle,
  :global(html.light-mode) .studio-details,
  :global(html.light-mode) .bio-desc,
  :global(html.light-mode) .bio-tagline {
    color: #86868b !important;
  }

  /* 所有的小标题与卡片：转换为纯正深黑 */
  :global(html.light-mode) .studio-card,
  :global(html.light-mode) .bio-title {
    color: #1d1d1f !important;
  }
  
</style>