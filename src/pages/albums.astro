---
// src/pages/albums.astro
import { SITE_CONFIG, ALBUMS_CONFIG } from '../config';
import Navbar from '../components/Navbar.astro';
// 引入刚刚剥离的纯净后端抓取引擎
import { fetchAllPhotos } from '../components/services/GooglePhotosFetcher';

// ========================================================
// 服务端数据同步 (SSR / SSG)
// ========================================================
const { photos: photosData, errorMsg } = await fetchAllPhotos();

const albumTitle = ALBUMS_CONFIG.title;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>{ALBUMS_CONFIG.nav} | {SITE_CONFIG.title}</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@100;400;700;900&family=Plus+Jakarta+Sans:wght@300;700;900&display=swap" rel="stylesheet">
</head>
<body>

  <Navbar />

  <main class="gallery-viewport" define:vars={{ themeColor: SITE_CONFIG.themeColor }}>
    
    <div class="header-section">
      <h1 class="page-title">{albumTitle}</h1>
      <p class="page-subtitle">{ALBUMS_CONFIG.subtitle}</p>
    </div>

    <div 
      id="album-data-store" 
      data-photos={JSON.stringify(photosData)} 
      data-error={errorMsg}
      style="display: none;"
    ></div>

    {errorMsg && (
      <div class="error-card">
        <div class="error-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 18c-.77 1.333.192 3 1.732 3z"/></svg>
        </div>
        <div class="error-content">
          <h3 class="error-title">画廊同步暂缓</h3>
          <p class="error-desc">{errorMsg}</p>
        </div>
      </div>
    )}

    <!-- 🔴 真正的物理隔离多列瀑布流容器 -->
    <div class="masonry-wrapper">
      <div id="masonry-grid" class="masonry-grid-flex"></div>
      <div id="scroll-sentinel" class="scroll-sentinel"></div>
    </div>

    <!-- Lightbox 全屏模态框 -->
    <div id="lightbox" class="lightbox-modal">
      <div class="lightbox-backdrop" id="lightbox-close-area"></div>
      
      <div class="lightbox-content">
        <div class="lightbox-header">
          <div class="meta-left">
            <span id="lightbox-index" class="meta-badge"></span>
            <span id="lightbox-date" class="meta-date"></span>
          </div>
          <button id="lightbox-close-btn" class="lightbox-close-btn" aria-label="关闭">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
          </button>
        </div>

        <div class="media-frame-container">
          <img id="lb-base-img" class="lightbox-layer opacity-hidden" />
          <img id="lb-high-img" class="lightbox-layer opacity-hidden" />
          <div id="lb-loader" class="lightbox-loading-placeholder" style="display: none;"></div>
        </div>

        <div class="lightbox-footer" id="lightbox-footer">
          <div class="footer-meta">
            <p id="footer-title" class="footer-title"></p>
            <p id="footer-date" class="footer-date"></p>
          </div>
          <a id="footer-link" href="#" target="_blank" rel="noopener noreferrer" class="footer-link">
            新窗口打开
          </a>
        </div>

        <button id="prev-btn" class="nav-btn prev" aria-label="上一张">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button id="next-btn" class="nav-btn next" aria-label="下一张">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>
  </main>

</body>
</html>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>

<script is:inline>
  const storeEl = document.getElementById('album-data-store');
  const rawPhotos = storeEl && storeEl.dataset.photos ? JSON.parse(storeEl.dataset.photos) : [];

  const getTakenAtValue = (takenAt) => {
    if (!takenAt) return Number.NEGATIVE_INFINITY;
    const parsed = Date.parse(takenAt);
    return Number.isNaN(parsed) ? Number.NEGATIVE_INFINITY : parsed;
  };

  const cachePool = [...rawPhotos].sort((left, right) => {
    const leftTakenAt = getTakenAtValue(left.takenAt);
    const rightTakenAt = getTakenAtValue(right.takenAt);
    if (leftTakenAt !== rightTakenAt) return rightTakenAt - leftTakenAt;
    if (left.index !== right.index) return left.index - right.index;
    return left.id.localeCompare(right.id);
  });

  let renderedCount = 0;  
  const REVEAL_BATCH = 15; 
  let activeIndex = null;  

  // 🔴 DOM 缓存池，彻底防止每次计算多列时卡片 DOM 被销毁重造
  const cardCache = [];

  function getColumnCount() {
    const w = window.innerWidth;
    if (w >= 1024) return 5; 
    if (w >= 640) return 2;  
    return 1;                
  }

  function initGallery() {
    if (cachePool.length === 0) return;
    window.dispatchEvent(new CustomEvent('quasar-album-sync', { detail: { showing: 0, cached: cachePool.length, isBuffering: true } }));
    setTimeout(() => {
      revealNextBatch(); 
      window.dispatchEvent(new CustomEvent('quasar-album-sync', { detail: { showing: renderedCount, cached: cachePool.length, isBuffering: false } }));
    }, 200); 
  }

  // 🔴 采用物理隔离的分列 Flex 组装机，绝对隔绝列交叉和溢出
  function renderGrid() {
    const gridContainer = document.getElementById('masonry-grid');
    gridContainer.innerHTML = '';
    
    const colCount = getColumnCount();
    const columns = [];

    // 创建纯粹隔离的列盒子
    for (let i = 0; i < colCount; i++) {
      const col = document.createElement('div');
      col.className = 'masonry-column-flex';
      gridContainer.appendChild(col);
      columns.push(col);
    }

    // 分发卡片到对应列中
    const visiblePhotos = cachePool.slice(0, renderedCount);
    visiblePhotos.forEach((photo, index) => {
      const targetColumn = columns[index % colCount];
      const cardEl = getOrCreateCard(photo, index);
      targetColumn.appendChild(cardEl);
    });
  }

  function getOrCreateCard(photo, index) {
    if (cardCache[index]) return cardCache[index];
    
    const card = createPhotoCard(photo, index);
    cardCache[index] = card;
    return card;
  }

  function revealNextBatch() {
    if (cachePool.length === 0 || renderedCount >= cachePool.length) return;
    
    renderedCount = Math.min(renderedCount + REVEAL_BATCH, cachePool.length);
    renderGrid();
    notifyNavbar();
  }

  function createPhotoCard(photo, index) {
    const card = document.createElement('div');
    card.className = 'masonry-item-card group';
    card.onclick = () => openLightbox(index);

    const aspect = photo.width && photo.height ? `${photo.width} / ${photo.height}` : 'auto';

    card.innerHTML = `
      <img 
        src="${photo.thumbUrl}" 
        alt="" 
        class="photo-img opacity-hidden"
        style="aspect-ratio: ${aspect};max-width: 100%;"
        onload="onImageLoaded(this)"
        onerror="onImageError(this, '${photo.fallbackThumbUrl}')"
      />
      ${photo.mediaType === 'video' ? `
        <div class="video-badge">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5.14v13.72a1 1 0 0 0 1.5.86l11-6.86a1 1 0 0 0 0-1.72l-11-6.86A1 1 0 0 0 8 5.14Z"/></svg>
        </div>
      ` : ''}
    `;
    return card;
  }

  window.onImageLoaded = (imgEl) => {
    imgEl.classList.remove('opacity-hidden');
    const cardEl = imgEl.closest('.masonry-item-card');
    if (!cardEl || cardEl.dataset.animated === "true") return;
    cardEl.dataset.animated = "true";

    const randomRotate = (Math.random() - 0.5) * 4; 
    
    gsap.fromTo(cardEl, 
      { y: 50, scale: 0.96, rotation: randomRotate, opacity: 0 }, 
      { y: 0, scale: 1, rotation: 0, opacity: 1, duration: 1.0, ease: "power4.out", clearProps: "transform,rotation" }
    );
  };

  window.onImageError = (imgEl, fallbackUrl) => {
    if (fallbackUrl && imgEl.dataset.fallbackApplied !== "true") {
      imgEl.dataset.fallbackApplied = "true";
      imgEl.src = fallbackUrl; 
    }
  };

  function notifyNavbar() {
    window.dispatchEvent(new CustomEvent('quasar-album-sync', { detail: { showing: renderedCount, cached: cachePool.length, isBuffering: false } }));
  }

  let resizeTimeout;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(() => { renderGrid(); }, 150);
  });

  const sentinel = document.getElementById('scroll-sentinel');
  const scrollObserver = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting) revealNextBatch();
  }, { rootMargin: '800px' });
  scrollObserver.observe(sentinel);


  // ==========================================
  // 大图预览：防溢出引擎
  // ==========================================
  const lightbox = document.getElementById('lightbox');
  const lbBaseImg = document.getElementById('lb-base-img');
  const lbHighImg = document.getElementById('lb-high-img');
  const lbLoader = document.getElementById('lb-loader');
  const frameContainer = document.querySelector('.media-frame-container');
  
  const lbIndex = document.getElementById('lightbox-index');
  const lbDate = document.getElementById('lightbox-date');
  const footerTitle = document.getElementById('footer-title');
  const footerDate = document.getElementById('footer-date');
  const footerLink = document.getElementById('footer-link');

  window.openLightbox = (index) => {
    activeIndex = index;
    const photo = cachePool[index];
    if (!photo) return;

    frameContainer.querySelectorAll('video').forEach(v => v.remove());

    lightbox.classList.add('active');
    gsap.fromTo('.lightbox-content', { scale: 0.95, y: 15 }, { scale: 1, y: 0, duration: 0.5, ease: "expo.out" });

    lbIndex.innerText = `#${index + 1} / ${cachePool.length}`;
    lbDate.innerText = photo.takenAt ? new Date(photo.takenAt).toLocaleDateString() : 'UNKNOWN DATE';
    footerTitle.innerText = photo.mediaType === 'video' ? `视频 #${index + 1}` : `图片 #${index + 1}`;
    footerDate.innerText = photo.takenAt ? new Date(photo.takenAt).toLocaleString() : '未知拍摄时间';
    footerLink.href = photo.videoUrl || photo.originalLikeUrl || photo.displayUrl;

    lbBaseImg.className = 'lightbox-layer opacity-hidden';
    lbHighImg.className = 'lightbox-layer opacity-hidden';
    lbLoader.style.display = 'block';

    if (photo.mediaType === 'video') {
      const video = document.createElement('video');
      video.className = 'lightbox-layer';
      video.controls = true;
      video.autoplay = true;
      video.playsInline = true;
      video.src = photo.videoUrl || photo.displayUrl;
      video.oncanplay = () => { lbLoader.style.display = 'none'; };
      video.onerror = () => {
        if (photo.fallbackVideoUrl && video.dataset.fallbackApplied !== "true") {
          video.dataset.fallbackApplied = "true";
          video.src = photo.fallbackVideoUrl;
          video.load();
        } else {
          lbLoader.style.display = 'none';
        }
      };
      frameContainer.appendChild(video);
    } else {
      lbBaseImg.src = photo.previewUrl || photo.displayUrl;
      
      lbBaseImg.onload = () => {
        lbLoader.style.display = 'none';
        lbBaseImg.classList.remove('opacity-hidden');
        lbHighImg.src = photo.originalLikeUrl || photo.displayUrl;
      };

      lbBaseImg.onerror = () => {
        lbBaseImg.src = photo.fallbackPreviewUrl || photo.fallbackDisplayUrl || photo.thumbUrl;
      };

      lbHighImg.onload = () => {
        lbHighImg.classList.remove('opacity-hidden');
      };

      lbHighImg.onerror = () => {
        lbHighImg.src = photo.fallbackOriginalLikeUrl || photo.fallbackDisplayUrl;
      };
    }
  };

  window.closeLightbox = () => {
    gsap.to('.lightbox-content', {
      scale: 0.95, y: 15, duration: 0.3, ease: "power2.in", onComplete: () => {
        lightbox.classList.remove('active');
        lbBaseImg.src = ''; 
        lbHighImg.src = '';
        lbLoader.style.display = 'none';
      }
    });
  };

  document.getElementById('lightbox-close-btn').addEventListener('click', closeLightbox);
  document.getElementById('lightbox-close-area').addEventListener('click', closeLightbox);
  document.getElementById('prev-btn').addEventListener('click', () => { if (activeIndex > 0) openLightbox(activeIndex - 1); });
  document.getElementById('next-btn').addEventListener('click', () => { if (activeIndex < cachePool.length - 1) openLightbox(activeIndex + 1); });
  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('active')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft' && activeIndex > 0) openLightbox(activeIndex - 1);
    if (e.key === 'ArrowRight' && activeIndex < cachePool.length - 1) openLightbox(activeIndex + 1);
  });

  initGallery();
</script>

<style>
  :global(html), :global(body) {
    margin: 0 !important;
    padding: 0 !important;
    background-color: #030303;
    color: #ffffff;
    /* 🔴 物理死锁横向溢出 */
    overflow-x: hidden !important; 
    width: 100% !important;
    transition: background-color 0.4s ease, color 0.4s ease;
  }

  .gallery-viewport {
    min-height: 100vh;
    padding: 120px 6% 60px 6%;
    font-family: 'Noto Sans SC', sans-serif;
    box-sizing: border-box; 
    width: 100% !important;
    overflow-x: hidden !important;
  }

  .header-section { max-width: 600px; margin-bottom: 50px; }
  .page-title {
    font-size: 3.2rem; font-weight: 900; letter-spacing: -0.04em;
    background: linear-gradient(180deg, #ffffff 60%, #999999 100%);
    -webkit-background-clip: text;
    margin-bottom: 12px;
  }
  .page-subtitle { font-size: 0.95rem; color: #888888; line-height: 1.6; font-weight: 400; transition: color 0.4s ease; }

  /* 🔴 磨砂玻璃风格错误卡片 */
  .error-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    margin: 40px auto;
    max-width: 600px;
    background: rgba(255, 59, 48, 0.06); /* 极淡的红底 */
    border: 1px solid rgba(255, 59, 48, 0.2);
    backdrop-filter: blur(12px);
    border-radius: 16px;
    color: #ff453a; /* 苹果风格的警示红 */
  }

  .error-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    opacity: 0.9;
  }

  .error-title {
    margin: 0 0 4px 0;
    font-size: 0.95rem;
    font-weight: 700;
  }

  .error-desc {
    margin: 0;
    font-size: 0.85rem;
    opacity: 0.8;
    line-height: 1.4;
  }

  /* 白昼模式适配 */
  :global(html.light-mode) .error-card {
    background: rgba(255, 59, 48, 0.05);
    border: 1px solid rgba(255, 59, 48, 0.15);
    color: #d63031;
  }
  
  /* =========================================
     🔴 终极战车：Flex 物理列隔离瀑布流 (绝对不可能溢出/重叠)
  ========================================= */
  .masonry-wrapper { 
    position: relative; 
    width: 100%; 
    max-width: 105rem; 
    margin: 0 auto; 
    box-sizing: border-box; 
  }
  
  .masonry-grid-flex { 
    display: flex; 
    width: 100%; 
    gap: 0.618rem; 
    box-sizing: border-box;
  }

  .masonry-column-flex {
    flex: 1;
    /* 🔴 列宽死锁骨骼：min-width: 0 彻底防止图片撑大列宽，物理层面切断横向撑爆网页的路径 */
    min-width: 0 !important; 
    display: flex;
    flex-direction: column;
    gap: 0.618rem;
    box-sizing: border-box;
  }
  
  @media (max-width: 1024px) { .masonry-grid-flex { gap: 20px; } .masonry-column-flex { gap: 20px; } }
  @media (max-width: 640px) { .masonry-grid-flex { gap: 16px; } .masonry-column-flex { gap: 16px; } }

  .masonry-item-card {
    position: relative;
    display: block;
    /* 🔴 填平一切大黑边：必须 100% 顶格吃满列容器的物理宽度 */
    width: 100% !important; 
    background: transparent !important; 
    border: none !important; 
    outline: none !important;
    padding: 0; margin: 0; 
    cursor: pointer; 
    border-radius: 16px; 
    box-sizing: border-box;
    overflow: hidden; 
    opacity: 0; 
    will-change: transform, opacity;
  }

  .photo-img { 
    width: 100% !important; 
    height: auto !important; 
    /* 🔴 自然等比，绝不裁切多余区域，且平滑无黑边拉满 */
    object-fit: cover; 
    display: block; 
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease; 
  }
  
  .masonry-item-card:hover .photo-img {
    transform: scale(1.03);
  }

  .opacity-hidden { opacity: 0 !important; }

  .video-badge {
    position: absolute; bottom: 16px; right: 16px;
    background: rgba(0, 0, 0, 0.65); backdrop-filter: blur(8px);
    width: 32px; height: 32px; border-radius: 50%; display: flex; justify-content: center; align-items: center; color: #ffffff; z-index: 3;
  }
  .video-badge svg { width: 14px; height: 14px; }
  .scroll-sentinel { height: 60px; width: 100%; }

  /* =========================================
     大图预览防溢出
  ========================================= */
  .media-frame-container {
    flex-grow: 1; display: block; overflow: hidden;
    position: relative; width: 100%; height: 75vh; margin: 15px 0;
  }

  .lightbox-layer {
    position: absolute; top: 0; left: 0; right: 0; bottom: 0; margin: auto;
    width: 100%; height: 100%;
    object-fit: contain !important; 
    border-radius: 12px;
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .lightbox-loading-placeholder {
    position: absolute; top: 0; left: 0; right: 0; bottom: 0; margin: auto;
    width: 36px; height: 36px; border: 3px solid rgba(255, 255, 255, 0.12);
    border-top-color: var(--themeColor, #ffffff); border-radius: 50%; animation: spin 0.85s cubic-bezier(0.6, 0.2, 0.2, 0.8) infinite; z-index: 5;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  #lb-base-img { z-index: 1; }
  #lb-high-img { z-index: 2; }

  /* =========================================
     Lightbox 其他控制台 UI
  ========================================= */
  .lightbox-modal { position: fixed; inset: 0; z-index: 9999; display: flex; justify-content: center; align-items: center; opacity: 0; pointer-events: none; transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .lightbox-modal.active { opacity: 1; pointer-events: auto; }
  .lightbox-backdrop { position: absolute; inset: 0; background: rgba(3, 3, 3, 0.65); backdrop-filter: blur(28px) saturate(220%); -webkit-backdrop-filter: blur(28px) saturate(220%); z-index: 1; }
  .lightbox-content { position: relative; z-index: 2; width: 100%; max-width: 1100px; height: 88vh; display: flex; flex-direction: column; justify-content: space-between; padding: 20px; box-sizing: border-box; }
  .lightbox-header { display: flex; justify-content: space-between; align-items: center; width: 100%; z-index: 10; }
  .meta-left { display: flex; align-items: center; gap: 12px; }
  .meta-badge { background: rgba(255, 255, 255, 0.1); padding: 6px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 700; font-family: 'Plus Jakarta Sans'; color: #ffffff; }
  .meta-date { font-size: 0.75rem; color: #888888; font-family: 'Plus Jakarta Sans'; }
  .lightbox-close-btn { background: rgba(255, 255, 255, 0.1); border: none; width: 38px; height: 38px; border-radius: 50%; color: #ffffff; display: flex; justify-content: center; align-items: center; cursor: pointer; transition: all 0.2s ease; }
  .lightbox-close-btn:hover { background: rgba(255, 255, 255, 0.2); transform: scale(1.05); }
  .lightbox-close-btn svg { width: 16px; height: 16px; }

  .lightbox-footer { display: flex; justify-content: space-between; align-items: center; width: 100%; max-width: 900px; margin: 0 auto; padding: 14px 24px; border-radius: 20px; background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.08); color: #ffffff; z-index: 10; transition: all 0.4s ease; }
  .footer-title { font-size: 0.9rem; font-weight: 700; margin: 0 0 4px 0; }
  .footer-date { font-size: 0.72rem; color: rgba(255, 255, 255, 0.6); margin: 0; font-family: 'Plus Jakarta Sans'; }
  .footer-link { display: inline-flex; align-items: center; background: rgba(255, 255, 255, 0.08); border: 1px solid rgba(255, 255, 255, 0.1); color: #ffffff; font-size: 0.8rem; font-weight: 500; padding: 8px 16px; border-radius: 30px; text-decoration: none; backdrop-filter: blur(10px); transition: all 0.2s ease; }
  .footer-link:hover { background: rgba(255, 255, 255, 0.18); transform: translateY(-1px); }

  .nav-btn { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(255, 255, 255, 0.08); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.08); width: 50px; height: 50px; border-radius: 50%; color: #ffffff; display: flex; justify-content: center; align-items: center; cursor: pointer; z-index: 10; transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
  .nav-btn:hover { background: rgba(255, 255, 255, 0.18); transform: translateY(-50%) scale(1.08); }
  .nav-btn.prev { left: -40px; }
  .nav-btn.next { right: -40px; }
  .nav-btn svg { width: 18px; height: 18px; }

  /* =========================================
     白昼模式
  ========================================= */
  :global(html.light-mode), :global(html.light-mode body) { background-color: #f5f5f7 !important; color: #1d1d1f !important; }
  :global(html.light-mode) .page-title { background: linear-gradient(180deg, #1d1d1f 40%, #86868b 100%); -webkit-background-clip: text;}
  :global(html.light-mode) .page-subtitle { color: #555555; }
  
  :global(html.light-mode) .masonry-item-card { background: transparent !important; border: none !important; box-shadow: none !important; }
  
  :global(html.light-mode) .lightbox-backdrop { background: rgba(255, 255, 255, 0.6); backdrop-filter: blur(36px) saturate(220%); -webkit-backdrop-filter: blur(36px) saturate(220%); }
